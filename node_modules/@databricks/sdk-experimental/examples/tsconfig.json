{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "node",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "lib": ["ES2020", "DOM", "ES2021.String", "esnext.disposable"],
        "baseUrl": ".",
        "paths": {
            "@databricks/sdk-experimental": ["../src/index"]
        }
    },
    "include": ["./**/*.ts"]
}
