{
    "name": "@databricks/sdk-experimental",
    "version": "0.16.0",
    "description": "Databricks SDK",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/databricks/databricks-sdk-js.git#main"
    },
    "license": "Apache-2.0",
    "bugs": {
        "url": "https://github.com/databricks/databricks-sdk-js/issues"
    },
    "publishConfig": {
        "access": "public",
        "tag": "latest",
        "registry": "https://registry.npmjs.org/"
    },
    "homepage": "https://github.com/databricks/databricks-sdk-js",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "/examples",
        "/dist",
        "NOTICE.md",
        "CHANGELOG.md"
    ],
    "engines": {
        "node": ">=22.0",
        "npm": ">=10.0.0"
    },
    "scripts": {
        "build": "tsc --build --force",
        "watch": "tsc --build --watch",
        "clean": "rm -rf dist node_modules",
        "generate:api": ".codegen/genkit update-sdk",
        "generate:notice": "./scripts/generate_notice.sh",
        "generate:tests": "deco code auth-tests && prettier src/config/UnifiedAuth.test.ts --write",
        "fix": "knip --fix; eslint src --ext ts --fix; prettier . --write && npm run generate:notice",
        "test:lint": "eslint src --ext ts && prettier . -c",
        "test:examples:types": "tsc --project examples/tsconfig.json --noEmit",
        "test:examples:lint": "eslint examples/auth --ext ts",
        "test:examples": "npm run test:examples:types && npm run test:examples:lint",
        "test:unit": "ts-mocha --type-check \"src/**/*.test.ts\"",
        "test": "npm run test:lint && npm run test:examples && npm run test:knip && npm run test:unit",
        "test:integ": "ts-mocha --type-check \"src/**/*.integ.ts\"",
        "test:cov": "nyc --report-dir ./coverage/unit npm run test:unit",
        "test:integ:cov": "nyc --report-dir ./coverage/integration npm run test:integ",
        "test:knip": "knip",
        "prepack": "npm run build"
    },
    "dependencies": {
        "google-auth-library": "^10.5.0",
        "ini": "^6.0.0",
        "reflect-metadata": "^0.2.2",
        "semver": "^7.7.3"
    },
    "devDependencies": {
        "@eslint/js": "^9.38.0",
        "@istanbuljs/nyc-config-typescript": "^1.0.2",
        "@sinonjs/fake-timers": "^15.0.0",
        "@types/ini": "^4.1.1",
        "@types/marked-terminal": "^6.1.1",
        "@types/mocha": "^10.0.10",
        "@types/node": "^22.0.0",
        "@types/semver": "^7.7.1",
        "@types/sinonjs__fake-timers": "^15.0.1",
        "@typescript-eslint/eslint-plugin": "^8.46.2",
        "@typescript-eslint/parser": "^8.46.2",
        "eslint": "^9.38.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-no-only-tests": "^3.3.0",
        "eventsource-parser": "^3.0.6",
        "globals": "^16.4.0",
        "knip": "^5.66.4",
        "marked": "^11.0.0",
        "marked-terminal": "^6.1.1",
        "mocha": "^11.7.4",
        "nyc": "^17.1.0",
        "prettier": "^3.6.2",
        "proxy-agent": "^6.5.0",
        "ts-mocha": "^11.1.0",
        "ts-mockito": "^2.6.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.9.3"
    },
    "nyc": {
        "extends": "@istanbuljs/nyc-config-typescript",
        "check-coverage": false,
        "all": true,
        "skip-empty": true,
        "include": [
            "src/**/*.ts"
        ],
        "exclude": [
            "src/**/*.test.ts",
            "src/**/*.integ.ts",
            "src/apis/**",
            "src/test/**"
        ],
        "reporter": [
            "lcov",
            "json"
        ],
        "report-dir": "coverage"
    }
}
